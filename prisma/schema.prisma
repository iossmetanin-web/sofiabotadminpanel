// Sofia Bot — Prisma schema
// Local dev: SQLite. Production (Vercel + Render bot): PostgreSQL (Neon/Supabase).
// To switch to PostgreSQL for Vercel deployment, change `provider` to "postgresql"
// and set DATABASE_URL to your hosted Postgres connection string.
//
// This schema is shared between:
//   - Next.js admin panel (Vercel serverless)
//   - Python bot (Render/Fly.io/Railway long-running, aiogram long polling)
// The Python bot uses the same DB via asyncpg/SQLAlchemy.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // For Vercel production: provider = "postgresql"
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                  String   @id @default(cuid())
  telegramId          String   @unique
  username            String?
  firstName           String?
  lastName            String?
  language            String   @default("ru")

  // Onboarding
  name                String?
  birthDate           DateTime?
  birthTime           String?
  birthPlace          String?
  gender              String?
  ageGroup            String?
  zodiacSign          String?
  onboardingCompleted Boolean  @default(false)
  onboardingStep      String   @default("START")

  // Currency
  crystals            Int      @default(3)

  // Subscription
  subscriptionType    String? // "weekly" | "monthly" | null
  subscriptionUntil   DateTime?

  // Retention
  streakDays          Int      @default(0)
  lastActivityDay     DateTime?
  lastSeenAt          DateTime?
  lastDailyCardAt     DateTime?
  lastFreeCardAt      DateTime?

  // Referral
  referredById        String?
  referralCode        String   @unique
  referralRewardGiven Boolean  @default(false)

  // Moderation
  rudenessCount       Int      @default(0)
  isBlocked           Boolean  @default(false)
  isAdmin             Boolean  @default(false)

  // Counters
  messageCount        Int      @default(0)
  dailyMessageCount   Int      @default(0)
  dailyMessageDate    DateTime?

  // Memory
  lastTopicSummary    String?

  // Timestamps
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  conversations       Conversation[]
  memories            Memory[]
  transactions        Transaction[]
  readings            Reading[]
  referralsMade       Referral[] @relation("Referrer")
  referralsReceived   Referral[] @relation("Referee")
  auditLogs           AuditLog[]

  @@index([username])
  @@index([referredById])
  @@index([lastSeenAt])
  @@index([subscriptionUntil])
  @@index([onboardingCompleted])
}

model Conversation {
  id          String   @id @default(cuid())
  userId      String
  role        String // "user" | "sofia"
  content     String
  emotionTag  String?
  tokensUsed  Int      @default(0)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Memory {
  id          String   @id @default(cuid())
  userId      String
  kind        String   // "fact" | "emotional"
  category    String   // fact: pain|relationship|work|family|goal|fear|promise|personality|health
                       // emotional: main_pain|loved_one|promise|unfinished_question|life_event|fear|goal|breakthrough
  content     String
  context     String?
  importance  Int      @default(3)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, kind, category, content])
  @@index([userId, importance])
}

model Transaction {
  id           String   @id @default(cuid())
  userId       String
  type         String // "spend" | "add" | "admin_gift" | "referral" | "subscription" | "daily_bonus"
  amount       Int
  description  String?
  balanceAfter Int?
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([type, createdAt])
}

model Reading {
  id            String   @id @default(cuid())
  userId        String
  type          String // "fate_card"|"tarot_small"|"tarot_full"|"tarot_love"|"tarot_career"|"tarot_decision"|"horoscope"|"single_card"|"card_of_day"
  question      String?
  cards         String // JSON array of {name, reversed, position}
  interpretation String
  cost          Int      @default(0)
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([type, createdAt])
}

model Referral {
  id          String   @id @default(cuid())
  referrerId  String
  refereeId   String
  rewardGiven Boolean  @default(false)
  createdAt   DateTime @default(now())

  referrer    User     @relation("Referrer", fields: [referrerId], references: [id])
  referee     User     @relation("Referee", fields: [refereeId], references: [id])

  @@unique([referrerId, refereeId])
}

model AuditLog {
  id           String   @id @default(cuid())
  actorId      String? // admin telegram id
  action       String
  targetUserId String?
  details      String?
  createdAt    DateTime @default(now())

  user         User?    @relation(fields: [actorId], references: [id])
}

model BotConfig {
  id        String   @id
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model Broadcast {
  id          String   @id @default(cuid())
  adminId     String
  text        String
  sentCount   Int      @default(0)
  failedCount Int      @default(0)
  total       Int      @default(0)
  status      String   @default("pending") // "pending"|"sending"|"done"|"failed"
  createdAt   DateTime @default(now())
}

/// Command queue: admin panel (Next.js/Vercel) → Python bot (Render).
/// Admin enqueues commands; the Python bot polls this table every ~2s
/// and executes them (broadcast, ban, gift crystals, send DM, etc.).
/// This decouples the serverless admin from the long-running bot.
model BotCommand {
  id         String   @id @default(cuid())
  // Command type: "broadcast" | "dm" | "ban" | "unban" | "gift_crystals"
  //             | "set_subscription" | "reload_config" | "shutdown"
  type       String
  // JSON payload specific to command type, e.g. {"telegramId":"123","text":"hi"}
  payload    String
  status     String   @default("pending") // "pending"|"processing"|"done"|"failed"
  result     String?  // JSON result/error from the bot
  createdAt  DateTime @default(now())
  startedAt  DateTime?
  finishedAt DateTime?

  @@index([status, createdAt])
  @@index([type, status])
}

/// Heartbeat: the Python bot updates this row every 15-30s.
/// Admin panel reads it to show online/offline status.
/// This works across Vercel (read-only) + Render (write) via shared DB.
model BotHeartbeat {
  id           String   @id @default("singleton")
  lastBeatAt   DateTime @default(now())
  pid          Int?
  hostname     String?
  version      String?
  uptime       Int? // seconds
  pollingMode  String  @default("long_polling") // "long_polling" | "webhook"
  @@index([lastBeatAt])
}
